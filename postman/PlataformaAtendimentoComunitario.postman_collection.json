{
  "info": {
    "name": "Plataforma Atendimento Comunitario IFMG",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "tokenCidadao", "value": "" },
    { "key": "tokenAtendente", "value": "" },
    { "key": "chamadoId", "value": "1" }
  ],
  "item": [
    {
      "name": "01 - Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "02 - Auth",
      "item": [
        {
          "name": "POST /auth/cadastro",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Usuario Teste\",\n  \"email\": \"usuario.teste@ifmg.com\",\n  \"senha\": \"123456\",\n  \"role\": \"cidadao\"\n}"
            },
            "url": "{{baseUrl}}/auth/cadastro"
          }
        },
        {
          "name": "POST /auth/login (cidadao)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('tokenCidadao', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@ifmg.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/login (atendente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('tokenAtendente', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@ifmg.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET /perfil",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenCidadao}}" }
            ],
            "url": "{{baseUrl}}/perfil"
          }
        },
        {
          "name": "GET /painel-atendimento",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAtendente}}" }
            ],
            "url": "{{baseUrl}}/painel-atendimento"
          }
        }
      ]
    },
    {
      "name": "03 - Chamados",
      "item": [
        {
          "name": "POST /chamados",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.chamado && jsonData.chamado.id) {",
                  "  pm.collectionVariables.set('chamadoId', jsonData.chamado.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenCidadao}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoria\": \"falta energia\",\n  \"descricao\": \"Sem energia na rua principal\",\n  \"cep\": \"35540000\",\n  \"prioridade\": \"alta\",\n  \"status\": \"ABERTO\"\n}"
            },
            "url": "{{baseUrl}}/chamados"
          }
        },
        {
          "name": "PATCH /chamados/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenCidadao}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"Descricao atualizada pelo cidadao\",\n  \"statusAtual\": \"ABERTO\"\n}"
            },
            "url": "{{baseUrl}}/chamados/{{chamadoId}}"
          }
        },
        {
          "name": "PATCH /chamados/:id/status (ABERTO->EM_ATENDIMENTO)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAtendente}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_ATENDIMENTO\",\n  \"observacao\": \"Equipe enviada\"\n}"
            },
            "url": "{{baseUrl}}/chamados/{{chamadoId}}/status"
          }
        },
        {
          "name": "PATCH /chamados/:id/status (EM_ATENDIMENTO->CONCLUIDO)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAtendente}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONCLUIDO\",\n  \"observacao\": \"Atendimento finalizado\"\n}"
            },
            "url": "{{baseUrl}}/chamados/{{chamadoId}}/status"
          }
        },
        {
          "name": "DELETE /chamados/:id (filtro seguro)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenCidadao}}" }
            ],
            "url": "{{baseUrl}}/chamados/{{chamadoId}}?statusAtual=ABERTO"
          }
        }
      ]
    },
    {
      "name": "04 - Relatorios e Indicadores",
      "item": [
        {
          "name": "GET /relatorios/chamados",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAtendente}}" }
            ],
            "url": "{{baseUrl}}/relatorios/chamados?status=ABERTO&categoria=FALTA_ENERGIA"
          }
        },
        {
          "name": "GET /indicadores/chamados",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAtendente}}" }
            ],
            "url": "{{baseUrl}}/indicadores/chamados"
          }
        }
      ]
    }
  ]
}
